{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet, noimageindex, noai" },
        { "key": "Cache-Control",  "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
